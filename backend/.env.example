# ============================================================
# Confidence Map — Backend Configuration
# ============================================================
# Copiar este archivo a .env y completar los valores.
# NUNCA commitear .env al repositorio de código.
# ============================================================

# ------------------------------------------------------------
# MODO DEMO
# true  → corre sin API key (datos pre-generados, $0 costo)
# false → usa Claude API real (requiere ANTHROPIC_API_KEY)
#
# Recomendado para desarrollo y presentaciones: true
# Recomendado para demo con calidad real:       false
# ------------------------------------------------------------
DEMO_MODE=true

# ------------------------------------------------------------
# ANTHROPIC API KEY
# Solo requerida cuando DEMO_MODE=false.
# Obtener en: https://console.anthropic.com → API Keys
# Formato: sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# IMPORTANTE: Esta key es un secret. No la compartas ni la
# incluyas en logs, respuestas HTTP ni código fuente.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ------------------------------------------------------------
# MODELO CLAUDE
# Solo aplica cuando DEMO_MODE=false.
#
# Opciones disponibles:
#   claude-haiku-4-5-20251001  → rápido, costo ~1x  (desarrollo)
#   claude-sonnet-4-6          → calidad alta, ~5x  (demo/prod)
#   claude-opus-4-6            → máxima calidad, ~15x (no recomendado para MVP)
#
# Costo estimado por análisis completo (6 agentes):
#   Haiku:  ~$0.003 USD
#   Sonnet: ~$0.05-0.10 USD
# ------------------------------------------------------------
MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
# URL del frontend (para CORS — solo orígenes explícitos permitidos)
FRONTEND_URL=http://localhost:3000
